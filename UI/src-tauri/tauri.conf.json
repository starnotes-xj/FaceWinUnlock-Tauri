{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "facewinunlock-tauri",
  "version": "0.3.5",
  "identifier": "com.administrator.facewinunlock-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "facewinunlock-tauri-吾爱破解首发",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../target/release/FaceWinUnlock_Tauri.dll": "resources/FaceWinUnlock-Tauri.dll",
      "../../target/release/FaceWinUnlock-Server.exe": "FaceWinUnlock-Server.exe",
      "D:\\OpenCV\\build\\x64\\vc16\\bin\\opencv_world4120.dll": "opencv_world4120.dll",
      "D:\\OpenCV\\build\\x64\\vc16\\bin\\opencv_videoio_ffmpeg4120_64.dll": "opencv_videoio_ffmpeg4120_64.dll",
      "../resources/face_detection_yunet_2023mar.onnx": "resources/face_detection_yunet_2023mar.onnx",
      "../resources/face_recognition_sface_2021dec.onnx": "resources/face_recognition_sface_2021dec.onnx",
      "../resources/face_liveness.onnx": "resources/face_liveness.onnx"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis/hooks.nsh",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
